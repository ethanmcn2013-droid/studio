{
  "name": "studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "bash scripts/check-suiteloader-identity.sh && tsx --test src/lib/hq/markdown.test.ts src/lib/hq/inbox.test.ts src/server/today/shape-native.test.ts",
    "test:ux": "node ux-tests/run-ux-tests.mjs",
    "test:ux:student": "node ux-tests/run-ux-tests.mjs --persona student",
    "test:ux:wedding": "node ux-tests/run-ux-tests.mjs --persona wedding-venue",
    "test:ux:full-flow": "node ux-tests/run-ux-tests.mjs --journey full-workflow",
    "test:ux:scenario": "node ux-tests/run-ux-tests.mjs --scenario full-workflow.student",
    "test:ux:keyboard": "node ux-tests/run-ux-tests.mjs --keyboard",
    "test:ux:mobile": "node ux-tests/run-ux-tests.mjs --mobile",
    "test:ux:ai": "node ux-tests/run-ux-tests.mjs --ai-change",
    "test:ux:env": "node ux-tests/utils/env-readiness.mjs --profile ux-demo",
    "test:ux:env:prod": "node ux-tests/utils/env-readiness.mjs --profile production",
    "test:ux:env:find": "node ux-tests/utils/find-env-sources.mjs",
    "test:ux:first-pass": "node ux-tests/run-first-pass.mjs",
    "test:ux:daily": "node ux-tests/run-first-pass.mjs",
    "test:ux:ci": "node ux-tests/run-first-pass.mjs",
    "test:ux:gallery": "node ux-tests/utils/generate-screenshot-gallery.mjs",
    "test:ux:actions": "node ux-tests/utils/generate-action-board.mjs",
    "test:ux:index": "node ux-tests/utils/generate-report-index.mjs",
    "test:ux:strict-console": "node ux-tests/run-ux-tests.mjs --strict-console",
    "test:ux:all-projects": "node ux-tests/run-ux-tests.mjs --all-projects",
    "test:ux:headed": "node ux-tests/run-ux-tests.mjs --headed",
    "test:ux:report": "node ux-tests/utils/print-latest-report.mjs",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:entitlement": "tsx scripts/seed-entitlement.ts",
    "create:sponsor": "tsx scripts/create-sponsor.ts",
    "issue:codes": "tsx scripts/issue-codes.ts",
    "venue:paid": "tsx scripts/mark-venue-paid.ts",
    "partner:digest": "tsx scripts/partner-digest.ts",
    "check:dead": "tsx scripts/cross-repo-symbol-check.ts",
    "metrics:smoke": "node scripts/blueprint-metrics-smoke.mjs"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "drizzle-orm": "^0.45.2",
    "gsap": "3.13.0",
    "lenis": "1.1.20",
    "mermaid": "^11.15.0",
    "next": "16.2.5",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
