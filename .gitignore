# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/
.playwright-mcp/
.responsive-audit/

# ux-test session artifacts (screenshots + env-readiness reports, 200MB+)
/ux-tests/

# Experience Quality OS runtime evidence. Approved baselines and generated
# machine/human reports remain tracked; raw candidate/diff/test runs do not.
/experience/output/screenshots/
/experience/output/diffs/
/experience/output/playwright-report/
/experience/output/playwright-results/
/experience/output/hq-gallery/
